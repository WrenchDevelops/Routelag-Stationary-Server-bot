# PathGen server — Railway / local dev
# Replay parsing via Osirion. Separate from the RouteLag routing VPS.

PATHGEN_HOST=0.0.0.0
PORT=8788
PATHGEN_AUTH_SECRET=change-me-before-deploy
PATHGEN_INVITE_CODES=ROUTELAG-BETA,SIGMA-BETA,DECKZEE-BETA,WRENCH-BETA,SIGMA-DALLAS,WRENCH-TEST,benderaiden826@gmail.com
PATHGEN_SERVICE_API_KEY=
# Short-lived PathGen JWTs (seconds). Default 7200 (2h).
# PATHGEN_TOKEN_TTL_SEC=7200
# Production hard-locks invite login. Dev may set:
# PATHGEN_ALLOW_INVITE_LOGIN=true
# PATHGEN_REQUIRE_CLERK_SUBJECT=false

# Clerk session verification (required in production)
# Prefer CLERK_ISSUER, or set CLERK_PUBLISHABLE_KEY to derive issuer from pk_test_/pk_live_.
CLERK_PUBLISHABLE_KEY=
CLERK_ISSUER=
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# Optional comma-separated checks:
# CLERK_AUDIENCES=
# CLERK_AUTHORIZED_PARTIES=

OSIRION_API_BASE_URL=
# Leave blank (recommended). Must be the API host (https://api.osirion.gg), never https://osirion.gg —
# the website returns HTML and breaks status polling with "Unexpected token < in JSON".
OSIRION_API_KEY=
OSIRION_WEBHOOK_SECRET=

REPLAY_UPLOAD_MAX_MB=250
REPLAY_STORAGE_DIR=data/replays/uploads
REPLAY_DATA_FILE=data/pathgen-db.json

# true = skip getMatchInfo on basic parse (~10 credits saved; owner fields still fill mode/duration)
BASIC_PARSE_PLAYERS_ONLY=true
REPLAY_FIRST_POLL_DELAY_MS=15000
REPLAY_POLL_INTERVAL_MS=30000
REPLAY_MAX_STATUS_POLLS=40

# Deep analyze limits (user-triggered only)
DEEP_ANALYZE_MONTHLY_LIMIT=10
DEEP_ANALYZE_DAILY_LIMIT=3
DEEP_ANALYZE_COOLDOWN_MS=120000

# Supabase (user profiles + Epic account links)
SUPABASE_URL=https://adnlcbsvbdlqtjibddoj.supabase.co
# Required — Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_DISABLED=true

# Epic Account Services (Connect) — secrets stay server-side only
EPIC_CLIENT_ID=
EPIC_CLIENT_SECRET=
# Must match a Redirect URL on the Epic client exactly:
# EPIC_REDIRECT_URI=https://routelag-stationary-server-bot-production.up.railway.app/api/epic/callback

# Discord OAuth (Connect) — secrets stay server-side only (do not put the bot token here)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must match a Redirect URL on the Discord app exactly:
# DISCORD_REDIRECT_URI=https://routelag-stationary-server-bot-production.up.railway.app/api/discord/callback
